      "created_by_ref": "identity--00000001-0000-4000-a000-000000000001",
      "name": "RoguePlanet Named Pipe",
      "description": "Hardcoded named pipe used for user-to-SYSTEM callback. No legitimate software uses this name.",
      "indicator_types": ["malicious-activity"],
      "pattern": "[file:name = '\\\\.\\\\pipe\\\\RoguePlanet']",
      "pattern_type": "stix",
