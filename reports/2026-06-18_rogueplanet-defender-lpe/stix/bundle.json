      "created_by_ref": "identity--00000001-0000-4000-a000-000000000001",
      "name": "RoguePlanet Working Directory",
      "description": "Working directory created in %TEMP% with RP_ prefix followed by UUID.",
      "indicator_types": ["malicious-activity"],
      "pattern": "[directory:path MATCHES '.*\\\\\\\\RP_[0-9a-fA-F\\\\-]{36}$']",
