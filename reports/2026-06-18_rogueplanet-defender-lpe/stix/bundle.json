      "name": "WDFOO ADS Stream",
      "description": "Alternate data stream created on wermgr.exe as oplock anchor. Exploit-specific name.",
      "indicator_types": ["malicious-activity"],
      "pattern": "[file:name MATCHES '.*:WDFOO$']",
