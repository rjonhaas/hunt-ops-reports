      "name": "wermgr.exe Modified in System32",
      "description": "Defender plants exploit payload at this path. Verify hash against known-good baseline.",
      "indicator_types": ["malicious-activity"],
      "pattern": "[file:parent_directory_ref.path = 'C:\\\\Windows\\\\System32' AND file:name = 'wermgr.exe']",
      "pattern_type": "stix",
